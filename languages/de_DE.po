#: src/Lib/Admin.php:356
msgid "XML-RPC FULL PROTECTION"
msgstr "XML-RPC VOLLSTÄNDIGER SCHUTZ"

#: src/Lib/Admin.php:358
msgid "Blocks all remote requests. Most commonly used to prevent all types of remote attacks."
msgstr ""
"Blockiert alle Remote-Anfragen. Wird am häufigsten verwendet, um alle Arten "
"von Remote-Angriffen zu verhindern."

#: src/Lib/Admin.php:362
msgid "XML-RPC LOGIN PROTECTION"
msgstr "XML-RPC ANMELDESCHUTZ"

#: src/Lib/Admin.php:364
msgid "Blocks remote login requests. Most commonly used to prevent brute force login attempts."
msgstr ""
"Blockiert Remote-Anmeldeanfragen. Wird am häufigsten verwendet, um Brute-"
"Force-Anmeldeversuche zu verhindern."

#: src/Lib/Admin.php:368
msgid "XML-RPC PINGBACK PROTECTION"
msgstr "XML-RPC PINGBACK-SCHUTZ"

#: src/Lib/Admin.php:370
msgid "Blocks remote pingback requests. Most commonly used to prevent DDoS attacks."
msgstr ""
"Blockiert Remote-Pingback-Anfragen. Wird meist verwendet, um DDoS-Angriffe "
"zu verhindern."

#: src/Lib/Admin.php:374
msgid "SELF PINGBACK PROTECTION"
msgstr "SCHUTZ DER EIGENEN PINGBACKS"

#: src/Lib/Admin.php:376
msgid "Blocks remote self-pingback requests. Most commonly used to prevent DDoS attacks."
msgstr ""
"Blockiert entfernte Self-Pingback-Anfragen. Wird meist verwendet, um DDoS-"
"Angriffe zu verhindern."

#: src/Lib/Admin.php:380
msgid "New Custom Login URL"
msgstr "Neue benutzerdefinierte Anmelde-URL"

#: src/Lib/Admin.php:382
msgid "Hides login url from the attackers."
msgstr "Versteckt die Login-Url vor den Angreifern."

#: src/Lib/Admin.php:386
msgid "Enable HTTPS / SSL"
msgstr "Aktivieren Sie HTTPS / SSL"

#: src/Lib/Admin.php:388
msgid "SSL automatically encrypts your privileged information data."
msgstr "SSL verschlüsselt automatisch Ihre vertraulichen Daten."

#: src/Lib/Admin.php:392
msgid "Force HTTPS Login"
msgstr "HTTPS-Anmeldung erzwingen"

#: src/Lib/Admin.php:394
